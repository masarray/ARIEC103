<Project>
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <ImplicitUsings>enable</ImplicitUsings>
    <AnalysisLevel>latest</AnalysisLevel>

    <Version>1.2.33</Version>
    <AssemblyVersion>1.2.33.0</AssemblyVersion>
    <FileVersion>1.2.33.0</FileVersion>
    <InformationalVersion>1.2.33-seo-hardening</InformationalVersion>
    <Authors>Ari Sulistiono</Authors>
    <Company>Ari Sulistiono</Company>
    <Product>ArIEC103</Product>
    <Copyright>Copyright © 2026 Ari Sulistiono</Copyright>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/masarray/ARIEC103</PackageProjectUrl>
    <RepositoryUrl>https://github.com/masarray/ARIEC103</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <NeutralLanguage>en</NeutralLanguage>
  </PropertyGroup>
</Project>
