<Window x:Class="ArIEC103.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArIEC103 - IEC-103 Master Tester"
        Width="1540" Height="900" MinWidth="1280" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/Icons/ariec103-icon.png"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        FontFamily="{StaticResource AppFont}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="18" Padding="8" ClipToBounds="False" Effect="{StaticResource SoftShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#FAFCFF" Offset="0.55" />
                    <GradientStop Color="#F3F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Center">
                <Border Width="68" Height="70" CornerRadius="18" Margin="0,0,0,13" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFF" Offset="0" />
                            <GradientStop Color="#F2F7FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image Source="Assets/Icons/ariec103-icon.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <Button x:Name="SetupButton" Style="{StaticResource RailIconButton}" Click="OpenSetup_Click" ToolTip="Setup connection and polling">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Style="{StaticResource RailIconPath}" Data="{StaticResource ArIconSetup}" />
                        <TextBlock Text="Setup" Style="{StaticResource RailButtonCaption}" />
                    </StackPanel>
                </Button>
                <Button x:Name="StartButton" Style="{StaticResource RailPrimaryIconButton}" Click="Start_Click" ToolTip="Connect and monitor continuously">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Style="{StaticResource RailIconPath}" Data="{StaticResource ArIconConnect}" />
                        <TextBlock Text="Connect" Style="{StaticResource RailButtonCaption}" />
                    </StackPanel>
                </Button>
                <Button x:Name="StopButton" Style="{StaticResource RailDangerIconButton}" Click="Stop_Click" IsEnabled="False" ToolTip="Disconnect and close transport">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Style="{StaticResource RailIconPath}" Data="{StaticResource ArIconDisconnect}" />
                        <TextBlock Text="Disconnect" Style="{StaticResource RailButtonCaption}" />
                    </StackPanel>
                </Button>
                <Button x:Name="ExportMarkdownButton" Style="{StaticResource RailIconButton}" Click="ExportMarkdown_Click" IsEnabled="False" ToolTip="Export evidence report">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Style="{StaticResource RailIconPath}" Data="{StaticResource ArIconReport}" />
                        <TextBlock Text="Export" Style="{StaticResource RailButtonCaption}" />
                    </StackPanel>
                </Button>
                <Button x:Name="ClearButton" Style="{StaticResource RailIconButton}" Click="Clear_Click" ToolTip="Clear visible session rows">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Style="{StaticResource RailIconPath}" Data="{StaticResource ArIconClear}" />
                        <TextBlock Text="Clear" Style="{StaticResource RailButtonCaption}" />
                    </StackPanel>
                </Button>

                <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="16" Padding="8" Margin="2,14,2,0" Width="68">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFF" Offset="0" />
                            <GradientStop Color="#F5F9FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="LOCK" Style="{StaticResource EyebrowText}" FontSize="8.8" HorizontalAlignment="Center" />
                        <TextBlock Text="C2" FontSize="10.2" Foreground="{StaticResource Ink700Brush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                        <TextBlock Text="C1 ACD" FontSize="10.2" Foreground="{StaticResource Ink700Brush}" HorizontalAlignment="Center" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border Style="{StaticResource HeaderShell}" MinHeight="58">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Universal IEC-103 Single Connection Master" Style="{StaticResource HeadingText}" FontSize="15.5" FontWeight="Normal" />
                            <TextBlock x:Name="SessionSubtitleText" Text="Ready. Open Setup, connect, then monitor continuously." Style="{StaticResource SubtleText}" FontSize="10.8" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="BufferStatusText" Text="UI buffer: ready" Style="{StaticResource SubtleText}" FontSize="10.2" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Style="{StaticResource InstrumentChip}" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxLed" Text="●" Style="{StaticResource LedText}" Foreground="{StaticResource AccentBrush}" Opacity="0.28" />
                                    <TextBlock x:Name="RxLed" Text="●" Style="{StaticResource LedText}" Foreground="{StaticResource GoodBrush}" Opacity="0.28" Margin="0,0,4,0" />
                                    <TextBlock Text="TX/RX " Style="{StaticResource ChipLabelText}" />
                                    <TextBlock x:Name="TxRxText" Text="0 / 0" Style="{StaticResource ChipValueText}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InstrumentChip}" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Class1Led" Text="●" Style="{StaticResource LedText}" Foreground="{StaticResource WarnBrush}" Opacity="0.28" />
                                    <TextBlock x:Name="Class2Led" Text="●" Style="{StaticResource LedText}" Foreground="{StaticResource AccentBrush}" Opacity="0.28" Margin="0,0,4,0" />
                                    <TextBlock Text="C1/C2 " Style="{StaticResource ChipLabelText}" />
                                    <TextBlock x:Name="ClassPollText" Text="0 / 0" Style="{StaticResource ChipValueText}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InstrumentChip}" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="NO DATA " Style="{StaticResource ChipLabelText}" />
                                    <TextBlock x:Name="NoDataText" Text="0" Style="{StaticResource ChipValueText}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InstrumentChip}" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="EventLed" Text="●" Style="{StaticResource LedText}" Foreground="{StaticResource BadBrush}" Opacity="0.28" />
                                    <TextBlock Text="EVENT " Style="{StaticResource ChipLabelText}" />
                                    <TextBlock x:Name="DpiText" Text="0" Style="{StaticResource ChipValueText}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InstrumentChip}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="DiagLed" Text="●" Style="{StaticResource LedText}" Foreground="{StaticResource BadBrush}" Opacity="0.28" />
                                    <TextBlock Text="FIND " Style="{StaticResource ChipLabelText}" />
                                    <TextBlock x:Name="FindingCountText" Text="0" Style="{StaticResource ChipValueText}" />
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="10,5" Width="132" Height="48" ClipToBounds="True" Effect="{StaticResource SoftShadow}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFFFFF" Offset="0" />
                                        <GradientStop Color="#F2F7FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="SESSION" Style="{StaticResource EyebrowText}" FontSize="9.8" />
                                    <TextBlock x:Name="StateText" Text="Idle" FontSize="12.4" FontWeight="Medium" Foreground="{StaticResource Ink900Brush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="CompletionText" Text="History below" Style="{StaticResource SubtleText}" FontSize="10.2" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12,12,18,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="SegmentedNavRoot" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="22" Padding="4" HorizontalAlignment="Left" Effect="{StaticResource SoftShadow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFF" Offset="0" />
                                    <GradientStop Color="#F5F8FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Border x:Name="SegmentSlider" Height="34" Width="126" CornerRadius="18" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False" Background="{StaticResource AccentBrush}">
                                    <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.18" Color="#2563EB" /></Border.Effect>
                                    <Border.RenderTransform><TranslateTransform x:Name="SegmentSliderTranslate" X="0" /></Border.RenderTransform>
                                </Border>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="NavOperatorButton" Content="Operator Evidence" Style="{StaticResource SegmentedNavButton}" Tag="0" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavFrameButton" Content="Frame Trace" Style="{StaticResource SegmentedNavButton}" Tag="1" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavValueButton" Content="Value Viewer" Style="{StaticResource SegmentedNavButton}" Tag="2" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavEventButton" Content="Event Log" Style="{StaticResource SegmentedNavButton}" Tag="3" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavAssessmentButton" Content="AutoTest" Style="{StaticResource SegmentedNavButton}" Tag="4" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavFindingsButton" Content="Findings" Style="{StaticResource SegmentedNavButton}" Tag="5" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavDiagnosticsButton" Content="Diagnostics" Style="{StaticResource SegmentedNavButton}" Tag="6" Click="SegmentedNav_Click" />
                                    <Button x:Name="NavNotesButton" Content="Session Notes" Style="{StaticResource SegmentedNavButton}" Tag="7" Click="SegmentedNav_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Button x:Name="ExportDataButton" Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="148" Height="34" Padding="12,6" HorizontalAlignment="Right" VerticalAlignment="Center" Click="ExportData_Click" ToolTip="Export selected tab grid as tab-separated .txt">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Style="{StaticResource CircleIconPath}" Data="{StaticResource ArIconDownload}" />
                                <TextBlock Text="Export Data" Margin="7,0,0,0" VerticalAlignment="Center" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="0" SelectedIndex="0" Style="{StaticResource ContentOnlyTabControl}" SelectionChanged="MainTabControl_SelectionChanged">
                    <TabItem Header="Operator Evidence">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="156" />
                            </Grid.RowDefinitions>
                            <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="EvidenceGrid" ItemsSource="{Binding EvidenceRows}" SelectionChanged="EvidenceGrid_SelectionChanged" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Sequence}" Width="52" />
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="92" />
                                    <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="54" />
                                    <DataGridTextColumn Header="Class" Binding="{Binding DataClass}" Width="78" />
                                    <DataGridTextColumn Header="Meaning" Binding="{Binding ReadableMeaning}" Width="2.4*" MinWidth="300" ElementStyle="{StaticResource GridCellMeaningText}" />
                                    <DataGridTextColumn Header="Action" Binding="{Binding OperatorAction}" Width="1.3*" MinWidth="190" ElementStyle="{StaticResource GridCellText}" />
                                    <DataGridTextColumn Header="Signal" Binding="{Binding SignalOrAddress}" Width="1.1*" MinWidth="170" ElementStyle="{StaticResource GridCellText}" />
                                    <DataGridTextColumn Header="Value" Binding="{Binding SemanticState}" Width="110" />
                                    <DataGridTextColumn Header="Relay Time" Binding="{Binding RelayTime}" Width="112" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Grid.Row="2" Background="{StaticResource Panel100Brush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="380" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Selected evidence: readable meaning" Style="{StaticResource EyebrowText}" />
                                        <TextBlock x:Name="SelectedDetailText" Text="Select evidence row to inspect decoded meaning." TextWrapping="Wrap" Foreground="{StaticResource Ink700Brush}" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Raw hex evidence" Style="{StaticResource EyebrowText}" />
                                        <TextBlock x:Name="SelectedRawText" Text="-" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource Ink700Brush}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Frame Trace">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.9*" MinWidth="760" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="0.68*" MinWidth="340" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel>
                                    <TextBlock Text="Line monitor — TX/RX transaction tracking. Select a frame; the right inspector explains the selected hex frame." Style="{StaticResource SubtleText}" FontSize="11.6" TextWrapping="Wrap" DockPanel.Dock="Left" />
                                    <TextBlock Text="Trace first, interpretation on the right" Style="{StaticResource EyebrowText}" Foreground="{StaticResource Ink500Brush}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                </DockPanel>
                                <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="FrameTraceGrid" Grid.Row="2" ItemsSource="{Binding FrameTraceRows}" SelectionChanged="EvidenceGrid_SelectionChanged" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" MinRowHeight="34">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="70" ElementStyle="{StaticResource GridCellWrapText}" />
                                        <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="40" ElementStyle="{StaticResource GridCellWrapText}" />
                                        <DataGridTextColumn Header="Class" Binding="{Binding DataClass}" Width="56" ElementStyle="{StaticResource GridCellWrapText}" />
                                        <DataGridTextColumn Header="Frame" Binding="{Binding RawHex}" Width="1.05*" MinWidth="180" ElementStyle="{StaticResource GridCellWrapCodeText}" />
                                        <DataGridTextColumn Header="ASDU / Service" Binding="{Binding AsduType}" Width="0.9*" MinWidth="110" ElementStyle="{StaticResource GridCellWrapText}" />
                                        <DataGridTextColumn Header="Signal / Address" Binding="{Binding SignalOrAddress}" Width="0.95*" MinWidth="120" ElementStyle="{StaticResource GridCellWrapText}" />
                                        <DataGridTextColumn Header="Meaning" Binding="{Binding ReadableMeaning}" Width="2.2*" MinWidth="260" ElementStyle="{StaticResource GridCellWrapMeaningText}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <Border Grid.Column="2" Background="{StaticResource Panel75Brush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Frame interpreter" Style="{StaticResource EyebrowText}" />
                                            <TextBlock x:Name="SelectedLineDirectionText" Text="Select a frame" FontSize="13" FontWeight="Medium" Foreground="{StaticResource Ink900Brush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="SelectedLineSummaryText" Text="Click any TX/RX row to see the full frame meaning here." Style="{StaticResource SubtleText}" FontSize="10.8" TextWrapping="Wrap" MaxHeight="34" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,0,0,0">
                                            <CheckBox x:Name="PinProtocolMapCheckBox" Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2" Background="Transparent" BorderThickness="0" CornerRadius="0" Padding="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="6" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <DockPanel>
                                                <TextBlock Text="Raw frame" Style="{StaticResource EyebrowText}" DockPanel.Dock="Left" />
                                                <TextBlock Text="grouped by IEC-103 field" Style="{StaticResource SubtleText}" FontSize="10.2" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                            </DockPanel>
                                            <ItemsControl Grid.Row="2" ItemsSource="{Binding SelectedHexSegments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource HexChipBorder}" ToolTip="{Binding Meaning}" MouseEnter="HexSegment_MouseEnter" MouseLeave="HexSegment_MouseLeave" MouseLeftButtonDown="HexSegment_MouseLeftButtonDown">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}" FontSize="9.5" Foreground="{StaticResource Ink500Brush}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Hex}" Style="{StaticResource HexChipText}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="4" Background="Transparent" BorderThickness="0" CornerRadius="0" Padding="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <DockPanel>
                                                <TextBlock Text="Decoded frame content" Style="{StaticResource EyebrowText}" DockPanel.Dock="Left" />
                                                <TextBlock Text="commissioning-readable" Style="{StaticResource SubtleText}" FontSize="10.2" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                            </DockPanel>
                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding SelectedProtocolMapLines}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource ProtocolMapLineBorder}" MouseEnter="ProtocolMapLine_MouseEnter" MouseLeave="ProtocolMapLine_MouseLeave" MouseLeftButtonDown="ProtocolMapLine_MouseLeftButtonDown">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="110" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding Title}" FontSize="11.2" FontWeight="Normal" Foreground="{StaticResource Ink900Brush}" TextWrapping="Wrap" />
                                                                        <TextBlock Text="{Binding Evidence}" FontSize="10.4" Foreground="{StaticResource Ink500Brush}" TextWrapping="Wrap" Margin="0,3,0,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="FontWeight" Value="Normal" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsCriticalData}" Value="True">
                                                                                            <Setter Property="FontWeight" Value="Medium" />
                                                                                            <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Meaning}" TextWrapping="Wrap" FontSize="11.2" Foreground="{StaticResource Ink700Brush}" Margin="10,0,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="FontWeight" Value="Normal" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCriticalData}" Value="True">
                                                                                        <Setter Property="FontWeight" Value="Medium" />
                                                                                        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Value Viewer">
                        <Grid Margin="14">
                            <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="ValueGrid" ItemsSource="{Binding ValueRows}" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Signal" Binding="{Binding Signal}" Width="2*" MinWidth="260" />
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="1*" MinWidth="130" />
                                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="1*" MinWidth="130" />
                                    <DataGridTextColumn Header="SOE Time" Binding="{Binding RelayTime}" Width="150" />
                                    <DataGridTextColumn Header="FUN/INF" Binding="{Binding FunInf}" Width="78" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*" MinWidth="130" />
                                    <DataGridTextColumn Header="COT" Binding="{Binding Cot}" Width="1.2*" MinWidth="150" />
                                    <DataGridTextColumn Header="Mapped" Binding="{Binding Mapped}" Width="74" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Event Log">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="Event Log uses relay timestamp from IEC-103 ASDU time fields. It records state change or spontaneous edge events from the relay, not every incoming frame." Style="{StaticResource SubtleText}" TextWrapping="Wrap" DockPanel.Dock="Left" />
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="16,0,0,0">
                                    <TextBlock Text="Filter" Style="{StaticResource EyebrowText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="EventLogFilterComboBox" Width="132" SelectedIndex="0" SelectionChanged="EventLogFilter_SelectionChanged" ToolTip="Filter event log by signal class">
                                        <ComboBoxItem Content="All" />
                                        <ComboBoxItem Content="Digital status" />
                                        <ComboBoxItem Content="Analog" />
                                    </ComboBox>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="RelayEventGrid" Grid.Row="2" ItemsSource="{Binding RelayEventRows}" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Sequence}" Width="52" />
                                    <DataGridTextColumn Header="SOE Time" Binding="{Binding RelayTime}" Width="150" />
                                    <DataGridTextColumn Header="Signal" Binding="{Binding Signal}" Width="2*" MinWidth="260" />
                                    <DataGridTextColumn Header="Previous" Binding="{Binding Previous}" Width="110" />
                                    <DataGridTextColumn Header="New" Binding="{Binding NewValue}" Width="110" />
                                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="1.4*" MinWidth="180" />
                                    <DataGridTextColumn Header="FUN/INF" Binding="{Binding FunInf}" Width="78" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*" MinWidth="120" />
                                    <DataGridTextColumn Header="COT" Binding="{Binding Cot}" Width="1*" MinWidth="130" />
                                    <DataGridTextColumn Header="Mapped" Binding="{Binding Mapped}" Width="74" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="AutoTest Assessment">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="AutoTest assessment converts the session evidence into a FAT/SAT-style checklist. It does not hide raw evidence; it summarizes communication activity, GI, polling policy, timing, values, mapping coverage, event timestamps, and findings." Style="{StaticResource SubtleText}" TextWrapping="Wrap" />
                            <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="AssessmentGrid" Grid.Row="2" ItemsSource="{Binding AssessmentRows}" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="120" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="82" />
                                    <DataGridTextColumn Header="Check" Binding="{Binding Title}" Width="1.2*" MinWidth="200" />
                                    <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="2*" MinWidth="280" />
                                    <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="1.5*" MinWidth="240" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Findings">
                        <Grid Margin="14">
                            <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="FindingsGrid" ItemsSource="{Binding FindingRows}" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="88" />
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="150" />
                                    <DataGridTextColumn Header="Finding" Binding="{Binding Title}" Width="1.4*" MinWidth="220" />
                                    <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="2*" MinWidth="280" />
                                    <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="1.5*" MinWidth="240" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Diagnostics">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="150" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="Runtime diagnostics capture transport exceptions, timeouts, mapping/load issues, warnings, and findings without crashing the operator workflow. Select a row to inspect or copy the full detail." Style="{StaticResource SubtleText}" TextWrapping="Wrap" DockPanel.Dock="Left" />
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <Button Content="Copy Row" Style="{StaticResource SecondaryButton}" Width="92" Click="CopySelectedDiagnostic_Click" />
                                    <Button Content="Copy Detail" Style="{StaticResource SecondaryButton}" Width="106" Margin="8,0,0,0" Click="CopyDiagnosticDetail_Click" />
                                </StackPanel>
                            </DockPanel>
                            <DataGrid PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown" x:Name="DiagnosticsGrid" Grid.Row="2" ItemsSource="{Binding DiagnosticRows}" SelectionChanged="DiagnosticsGrid_SelectionChanged" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copy selected diagnostic row" Click="CopySelectedDiagnostic_Click" />
                                        <MenuItem Header="Copy diagnostic detail" Click="CopyDiagnosticDetail_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="92" />
                                    <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="82" />
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110" />
                                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="160" />
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="1.6*" MinWidth="240" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="2*" MinWidth="280" />
                                    <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="1.4*" MinWidth="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBox x:Name="DiagnosticDetailBox" Grid.Row="4" Text="Select a diagnostic row to view complete detail." IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="12" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Session Notes">
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource Panel100Brush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="16" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Master strategy" FontWeight="Medium" FontSize="16" />
                                    <TextBlock Text="ArIEC103 runs as a single IEC-103 master connected to one protection relay slave. Demo mode uses an internal simulated slave so the complete workflow can be checked without hardware. Real mode uses the selected serial COM port." Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBox x:Name="SessionLogBox" Grid.Row="2" Height="Auto" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="12" />
                        </Grid>
                    </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="StatusHistoryPanel" Grid.Row="1" Grid.Column="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="16" Padding="10,8" Margin="0,10,0,0" Effect="{StaticResource SoftShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#FAFCFF" Offset="0.55" />
                    <GradientStop Color="#F2F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="StatusHistoryGapRow" Height="8" />
                    <RowDefinition x:Name="StatusHistoryContentRow" Height="118" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="9" Height="9" CornerRadius="5" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Status history" FontSize="12.6" FontWeight="Medium" Foreground="{StaticResource Ink900Brush}" Margin="0,0,10,0" />
                        <TextBlock x:Name="StatusHistorySummaryText" Text="No active session" Style="{StaticResource SubtleText}" FontSize="12" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Width="98" Height="32" Padding="8,4" Click="ToggleStatusHistory_Click" ToolTip="Collapse or expand status history">
                        <StackPanel Orientation="Horizontal">
                            <Path x:Name="StatusHistoryToggleIcon" Style="{StaticResource CircleIconPath}" Data="{StaticResource ArIconChevronDownCircle}" />
                            <TextBlock x:Name="StatusHistoryToggleText" Text="Hide" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
                <DataGrid x:Name="StatusHistoryGrid" Grid.Row="2" ItemsSource="{Binding StatusHistoryRows}" IsReadOnly="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="92" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" ElementStyle="{StaticResource GridCellText}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid x:Name="SetupOverlay" Grid.RowSpan="2" Grid.ColumnSpan="3" Visibility="Collapsed" Background="#770F172A" Panel.ZIndex="20">
            <Border Style="{StaticResource Card}" Width="760" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Connection Setup" Style="{StaticResource HeadingText}" FontSize="18" />
                            <TextBlock Text="Keep the cockpit clean. Communication parameters live here; line monitor stays focused on protocol observation." Style="{StaticResource SubtleText}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Style="{StaticResource SecondaryButton}" Width="88" Click="CloseSetup_Click" />
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TARGET MODE" Style="{StaticResource EyebrowText}" Margin="0,0,0,8" />
                            <ComboBox x:Name="TransportModeComboBox" SelectedIndex="0" Margin="0,0,0,12">
                                <ComboBoxItem Content="Serial COM - real relay" />
                                <ComboBoxItem Content="Generic relay demo - simulated slave" />
                            </ComboBox>
                            <TextBlock Text="CONNECTION" Style="{StaticResource EyebrowText}" Margin="0,4,0,8" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="94"/></Grid.ColumnDefinitions>
                                <ComboBox x:Name="PortComboBox" Grid.Column="0" />
                                <Button Grid.Column="2" Content="Refresh" Style="{StaticResource SecondaryButton}" Click="RefreshPorts_Click" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Baudrate" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="BaudComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="9600" />
                                        <ComboBoxItem Content="19200" />
                                        <ComboBoxItem Content="38400" />
                                        <ComboBoxItem Content="57600" />
                                        <ComboBoxItem Content="115200" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Serial" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="SerialModeComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="8E1" />
                                        <ComboBoxItem Content="8N1" />
                                        <ComboBoxItem Content="8O1" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Link Address" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <TextBox x:Name="LinkAddressBox" Text="1" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Common Address" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <TextBox x:Name="CommonAddressBox" Text="1" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="POLLING POLICY" Style="{StaticResource EyebrowText}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="C2 interval (ms)" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <TextBox x:Name="Class2IntervalBox" Text="500" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max C1 drain" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <TextBox x:Name="MaxDrainBox" Text="64" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Timeout (ms)" Style="{StaticResource SubtleText}" Margin="0,0,0,4" />
                                    <TextBox x:Name="TimeoutBox" Text="1500" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Session timeout (s)" Style="{StaticResource SubtleText}" Margin="0,0,0,4" ToolTip="0 means monitor continuously until Stop." />
                                    <TextBox x:Name="DurationBox" Text="0" ToolTip="0 means monitor continuously until Stop." />
                                </StackPanel>
                            </Grid>
                            <CheckBox x:Name="ResetRemoteLinkCheckBox" Content="Reset remote link on connect" />
                            <CheckBox x:Name="ResetFcbCheckBox" Content="Reset FCB on connect" IsChecked="True" />
                            <CheckBox x:Name="ClockSyncCheckBox" Content="Send clock sync on connect" />
                            <CheckBox x:Name="GiCheckBox" Content="General interrogation on connect" IsChecked="True" />
                            <CheckBox x:Name="Class2StartupCheckBox" Content="Request Class 2 after startup" IsChecked="True" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="4" Background="{StaticResource Panel100Brush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="98"/><ColumnDefinition Width="10"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="USER MAPPING PROFILE" Style="{StaticResource EyebrowText}" />
                                <TextBlock x:Name="MappingProfileStatusText" Text="No mapping profile loaded. Raw FUN/INF will be shown." Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,3,0,6" />
                                <TextBox x:Name="MappingProfilePathBox" IsReadOnly="True" />
                            </StackPanel>
                            <Button x:Name="BrowseMappingButton" Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}" Click="BrowseMapping_Click" VerticalAlignment="Bottom" />
                            <Button x:Name="ClearMappingButton" Grid.Column="4" Content="Clear Mapping" Style="{StaticResource SecondaryButton}" Click="ClearMapping_Click" VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
