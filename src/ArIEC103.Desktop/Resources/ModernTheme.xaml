<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore">
    <!-- mature engineering software identity: calm engineering surface, blue accent, soft cards, crisp data grids. -->
    <Color x:Key="Ink900">#111827</Color>
    <Color x:Key="Ink800">#1F2937</Color>
    <Color x:Key="Ink700">#374151</Color>
    <Color x:Key="Ink600">#475467</Color>
    <Color x:Key="Ink500">#667085</Color>
    <Color x:Key="Line200">#ECF1F8</Color>
    <Color x:Key="Line300">#DEE8F4</Color>
    <Color x:Key="Panel50">#F5F7FB</Color>
    <Color x:Key="Panel75">#F8FAFF</Color>
    <Color x:Key="Panel100">#EEF3FF</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Accent600">#2563EB</Color>
    <Color x:Key="Accent700">#1D4ED8</Color>
    <Color x:Key="AccentSoft">#EAF1FF</Color>
    <Color x:Key="Good600">#059669</Color>
    <Color x:Key="Warn600">#D97706</Color>
    <Color x:Key="Bad600">#DC2626</Color>

    <SolidColorBrush x:Key="Ink900Brush" Color="{StaticResource Ink900}" />
    <SolidColorBrush x:Key="Ink800Brush" Color="{StaticResource Ink800}" />
    <SolidColorBrush x:Key="Ink700Brush" Color="{StaticResource Ink700}" />
    <SolidColorBrush x:Key="Ink600Brush" Color="{StaticResource Ink600}" />
    <SolidColorBrush x:Key="Ink500Brush" Color="{StaticResource Ink500}" />
    <SolidColorBrush x:Key="LineBrush" Color="{StaticResource Line200}" />
    <SolidColorBrush x:Key="LineStrongBrush" Color="{StaticResource Line300}" />
    <SolidColorBrush x:Key="Panel50Brush" Color="{StaticResource Panel50}" />
    <SolidColorBrush x:Key="Panel75Brush" Color="{StaticResource Panel75}" />
    <SolidColorBrush x:Key="Panel100Brush" Color="{StaticResource Panel100}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent600}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource Accent700}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
    <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource Good600}" />
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource Warn600}" />
    <SolidColorBrush x:Key="BadBrush" Color="{StaticResource Bad600}" />

    <FontFamily x:Key="AppFont">Aptos, Segoe UI Variable Text, Segoe UI, Calibri</FontFamily>
    <DropShadowEffect x:Key="CardShadow" BlurRadius="30" ShadowDepth="10" Opacity="0.055" Color="#172033" />
    <DropShadowEffect x:Key="SoftShadow" BlurRadius="20" ShadowDepth="5" Opacity="0.055" Color="#172033" />
    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="18" ShadowDepth="5" Opacity="0.16" Color="#2563EB" />

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F7FAFF" Offset="0" />
                    <GradientStop Color="#F2F5FA" Offset="0.55" />
                    <GradientStop Color="#EEF3FF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
    </Style>

    <Style TargetType="Control">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#FCFEFF" Offset="0.45" />
                    <GradientStop Color="#F3F7FF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="17" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="CompactCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#F8FBFF" Offset="0.62" />
                    <GradientStop Color="#EEF5FF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InstrumentChip" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#F8FBFF" Offset="0.62" />
                    <GradientStop Color="#F1F6FF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="9,5" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
    </Style>

    <Style x:Key="HeaderShell" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#FAFCFF" Offset="0.55" />
                    <GradientStop Color="#F2F7FF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
    </Style>

    <Style x:Key="LedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,5,0" />
    </Style>

    <Style x:Key="ChipLabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{StaticResource Ink500Brush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ChipValueText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="12.2" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SoftPanel" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F5F8FF" Offset="0" />
                    <GradientStop Color="#EEF4FF" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="EyebrowText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Ink500Brush}" />
        <Setter Property="FontSize" Value="10.8" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style x:Key="HeadingText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="23" />
    </Style>

    <Style x:Key="SubtleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Ink500Brush}" />
        <Setter Property="FontSize" Value="11.8" />
        <Setter Property="LineHeight" Value="16" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="CaretBrush" Value="{StaticResource Ink900Brush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#F7F9FD" />
                            <Setter Property="Foreground" Value="{StaticResource Ink700Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="IsTextSearchEnabled" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="DropDownToggle"
                                      Style="{StaticResource ComboBoxToggleButton}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press" />
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                IsHitTestVisible="False">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  Margin="12,0,34,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                                <TextBox x:Name="PART_EditableTextBox"
                                         Style="{x:Null}"
                                         Margin="12,0,34,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         Visibility="Hidden"
                                         IsReadOnly="{TemplateBinding IsReadOnly}" />
                                <Path x:Name="Arrow"
                                      Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{StaticResource Ink600Brush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,13,0" />
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Background="White"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="4"
                                    Margin="0,4,0,0"
                                    Effect="{StaticResource SoftShadow}">
                                <ScrollViewer MaxHeight="260" CanContentScroll="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Chrome" Property="Background" Value="#FBFEFF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#BFDBFE" />
                            <Setter TargetName="Chrome" Property="Background" Value="#FAFDFF" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#F7F9FD" />
                            <Setter Property="Foreground" Value="{StaticResource Ink500Brush}" />
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            <Setter TargetName="DropDownToggle" Property="IsEnabled" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemChrome" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="#ECFEFF" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="#DBEAFE" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Ink700Brush}" />
        <Setter Property="FontSize" Value="12.3" />
        <Setter Property="Margin" Value="0,5,0,0" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="FontSize" Value="12.6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True" Margin="4,3">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="14" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1" /></Border.RenderTransform>
                            <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.13" Color="#38BDF8" /></Border.Effect>
                        </Border>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#7DD3FC" />
                            <Trigger.EnterActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.018" Duration="0:0:0.14" />
                                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.018" Duration="0:0:0.14" />
                                </Storyboard></BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.17" />
                                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.17" />
                                </Storyboard></BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.94" />
                            <Setter TargetName="Chrome" Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="0.982" ScaleY="0.982" /></Setter.Value></Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.52" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="Background" Value="#EEF3FF" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style x:Key="RailIconPath" TargetType="Path">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="RailIconButton" TargetType="Button">
        <Setter Property="Width" Value="68" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Margin" Value="0,5" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="#F4F8FF" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="4">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="18" RenderTransformOrigin="0.5,0.5">
                            <Border.BorderBrush>#E2EAF7</Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="#172033" /></Border.Effect>
                        </Border>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
                            <Setter TargetName="Chrome" Property="Background" Value="#EAF4FF" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#B8D7FF" />
                            <Setter TargetName="Chrome" Property="Effect"><Setter.Value><DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.10" Color="#38BDF8" /></Setter.Value></Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.44" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RailPrimaryIconButton" TargetType="Button" BasedOn="{StaticResource RailIconButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="RailDangerIconButton" TargetType="Button" BasedOn="{StaticResource RailIconButton}">
        <Setter Property="Background" Value="#DC2626" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="CircleIconPath" TargetType="Path">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>


    <Style x:Key="RailButtonCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="9.4" />
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="GridCellText" TargetType="TextBlock">
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
    </Style>

    <Style x:Key="GridCellMeaningText" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="GridCellCodeText" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="10.8" />
        <Setter Property="Foreground" Value="{StaticResource Ink700Brush}" />
    </Style>

    <Style x:Key="GridCellWrapText" TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="LineHeight" Value="15" />
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
    </Style>

    <Style x:Key="GridCellWrapMeaningText" TargetType="TextBlock" BasedOn="{StaticResource GridCellWrapText}">
        <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
    </Style>

    <Style x:Key="GridCellWrapCodeText" TargetType="TextBlock" BasedOn="{StaticResource GridCellWrapText}">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="10.6" />
        <Setter Property="Foreground" Value="{StaticResource Ink700Brush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="SelectionMode" Value="Extended" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="ClipboardCopyMode" Value="IncludeHeader" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Header="Copy selected row(s)" Command="{x:Static input:ApplicationCommands.Copy}" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="ClipboardCopyMode" Value="IncludeHeader" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinRowHeight" Value="30" />
        <Setter Property="ColumnHeaderHeight" Value="28" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="AlternatingRowBackground" Value="#FBFCFF" />
        <Setter Property="FontSize" Value="11.8" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F1F5F9" />
        <Setter Property="Foreground" Value="{StaticResource Ink600Brush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Border x:Name="RowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Margin="4,2"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1" /></Border.RenderTransform>
                        <DataGridCellsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBorder" Property="Background" Value="#F4F8FF" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBorder" Property="Background" Value="#EAF2FF" />
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="#C7DAFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style x:Key="HexChipText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="11.1" />
        <Setter Property="Foreground" Value="{StaticResource Ink800Brush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="HexChipBorder" TargetType="Border">
        <Setter Property="Background" Value="#F5F8FF" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EAF3FF" />
                <Setter Property="BorderBrush" Value="#8CB9FF" />
            </Trigger>
            <DataTrigger Binding="{Binding IsActive}" Value="True">
                <Setter Property="Background" Value="#DBEAFE" />
                <Setter Property="BorderBrush" Value="#2563EB" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ProtocolMapLineBorder" TargetType="Border">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,5" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F7FAFF" />
                <Setter Property="BorderBrush" Value="#BFD5FF" />
            </Trigger>
            <DataTrigger Binding="{Binding IsActive}" Value="True">
                <Setter Property="Background" Value="#EAF3FF" />
                <Setter Property="BorderBrush" Value="#2563EB" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InspectorExpander" TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource Ink700Brush}" />
        <Setter Property="FontSize" Value="11.8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border Background="Transparent">
                        <DockPanel LastChildFill="True">
                            <ToggleButton x:Name="HeaderSite"
                                          DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="#F3F7FF"
                                          BorderBrush="{StaticResource LineBrush}"
                                          BorderThickness="1"
                                          Padding="10,6"
                                          HorizontalContentAlignment="Stretch"
                                          Cursor="Hand">
                                <DockPanel>
                                    <TextBlock Text="⌄" Margin="0,0,8,0" Foreground="{StaticResource Ink500Brush}" />
                                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                                </DockPanel>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" DockPanel.Dock="Bottom" Visibility="Collapsed" Margin="0,8,0,0" />
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="ContentOnlyTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                      ContentSource="SelectedContent"
                                      SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SegmentedNavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Ink600Brush}" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="Height" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12.2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.74" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border HorizontalAlignment="Left" Background="#F9FCFF" BorderBrush="#E6F0FF" BorderThickness="1" CornerRadius="22" Padding="4" Margin="12,12,12,10" Effect="{StaticResource SoftShadow}">
                            <TabPanel x:Name="HeaderPanel" IsItemsHost="True" KeyboardNavigation.TabIndex="1" Background="Transparent" />
                        </Border>
                        <ContentPresenter x:Name="PART_SelectedContentHost" Grid.Row="1" ContentSource="SelectedContent" SnapsToDevicePixels="True" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource Ink600Brush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="13,7" />
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Border x:Name="Pill" CornerRadius="17" Background="Transparent" Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform ScaleX="0.82" ScaleY="0.96" /></Border.RenderTransform>
                        </Border>
                        <ContentPresenter x:Name="HeaderContent" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
                            <Setter TargetName="Pill" Property="Background" Value="#ECFEFF" />
                            <Setter TargetName="Pill" Property="Opacity" Value="1" />
                            <Trigger.EnterActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.045" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.045" Duration="0:0:0.15" />
                                </Storyboard></BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.20" />
                                    <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.20" />
                                </Storyboard></BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Pill" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                    <DoubleAnimation Storyboard.TargetName="Pill" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.82" To="1" Duration="0:0:0.20" />
                                    <DoubleAnimation Storyboard.TargetName="Pill" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.96" To="1" Duration="0:0:0.20" />
                                </Storyboard></BeginStoryboard>
                            </Trigger.EnterActions>
                            <Setter Property="Panel.ZIndex" Value="10" />
                            <Setter Property="Foreground" Value="{StaticResource Ink900Brush}" />
                            <Setter TargetName="Pill" Property="Opacity" Value="1" />
                            <Setter TargetName="Pill" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#BAE6FD" Offset="0" />
                                        <GradientStop Color="#93C5FD" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Pill" Property="Effect"><Setter.Value><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.16" Color="#38BDF8" /></Setter.Value></Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InvisibleScrollBarButton" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" /></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style x:Key="VerticalScrollBarThumb" TargetType="Thumb">
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb"><Border x:Name="ThumbBorder" Width="5" MinHeight="64" HorizontalAlignment="Center" Background="#CBD5E1" CornerRadius="3" Opacity="0.86" /><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBorder" Property="Width" Value="6" /><Setter TargetName="ThumbBorder" Property="Background" Value="#94A3B8" /></Trigger><Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBorder" Property="Width" Value="6" /><Setter TargetName="ThumbBorder" Property="Background" Value="#64748B" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style x:Key="HorizontalScrollBarThumb" TargetType="Thumb">
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb"><Border x:Name="ThumbBorder" Height="5" MinWidth="72" VerticalAlignment="Center" Background="#CBD5E1" CornerRadius="3" Opacity="0.86" /><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBorder" Property="Height" Value="6" /><Setter TargetName="ThumbBorder" Property="Background" Value="#94A3B8" /></Trigger><Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBorder" Property="Height" Value="6" /><Setter TargetName="ThumbBorder" Property="Background" Value="#64748B" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Width="8" Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource InvisibleScrollBarButton}" Command="ScrollBar.PageUpCommand" /></Track.DecreaseRepeatButton>
                            <Track.Thumb><Thumb Style="{StaticResource VerticalScrollBarThumb}" /></Track.Thumb>
                            <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource InvisibleScrollBarButton}" Command="ScrollBar.PageDownCommand" /></Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="8" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Height="8" Background="Transparent">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource InvisibleScrollBarButton}" Command="ScrollBar.PageLeftCommand" /></Track.DecreaseRepeatButton>
                                    <Track.Thumb><Thumb Style="{StaticResource HorizontalScrollBarThumb}" /></Track.Thumb>
                                    <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource InvisibleScrollBarButton}" Command="ScrollBar.PageRightCommand" /></Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
